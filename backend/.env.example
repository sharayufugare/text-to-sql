# ════════════════════════════════════════════════════════════
#  NL2SQL Backend – Environment Variables
#  Copy this file to `.env` and fill in YOUR values.
#  NEVER commit your real .env to Git.
# ════════════════════════════════════════════════════════════

# ── MySQL Connection ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=nl2sql_db

# ── LLM Provider ─────────────────────────────────────────────
# Choose ONE: openrouter | openai | claude
LLM_PROVIDER=openrouter

# ── OpenRouter (default, free tier available) ─────────────────
# Sign up at https://openrouter.ai → Dashboard → API Keys
OPENROUTER_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Free models on OpenRouter (change LLM_MODEL to use them):
#   mistralai/mistral-7b-instruct       ← default, fast & free
#   microsoft/phi-3-mini-128k-instruct  ← also free
#   meta-llama/llama-3-8b-instruct      ← good quality, free
#
# Paid models with better SQL accuracy:
#   openai/gpt-4o-mini
#   anthropic/claude-3-haiku
#   google/gemini-flash-1.5
LLM_MODEL=mistralai/mistral-7b-instruct

# ── OpenAI (if LLM_PROVIDER=openai) ──────────────────────────
# Sign up at https://platform.openai.com
OPENAI_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=gpt-3.5-turbo

# ── Anthropic Claude (if LLM_PROVIDER=claude) ────────────────
# Sign up at https://console.anthropic.com
ANTHROPIC_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=claude-3-haiku-20240307

# ── Flask ─────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
